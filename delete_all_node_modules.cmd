@echo off
setlocal enabledelayedexpansion

REM Usage: %~nx0 "C:\path\to\root" [/delete] [/y]
REM
REM Finds node_modules directories under the given root that sit beside a
REM package.json (i.e. genuine Node.js projects). By default runs in dry-run
REM mode and only lists what it would delete.
REM
REM   /delete  Delete targets, asking permission for each
REM   /y       Delete all targets without prompting

SET "ROOT_DIR="
SET "DO_DELETE=0"
SET "SKIP_CONFIRM=0"

REM --- Parse arguments ---
FOR %%A IN (%*) DO (
    IF /I "%%~A"=="/delete" (
        SET "DO_DELETE=1"
    ) ELSE IF /I "%%~A"=="/y" (
        SET "DO_DELETE=1"
        SET "SKIP_CONFIRM=1"
    ) ELSE (
        IF NOT DEFINED ROOT_DIR SET "ROOT_DIR=%%~A"
    )
)

IF NOT DEFINED ROOT_DIR (
    echo Usage: %~nx0 "C:\path\to\root" [/delete] [/y]
    echo.
    echo   /delete  Delete targets, asking permission for each
    echo   /y       Delete all targets without prompting
    exit /b 1
)

IF NOT EXIST "%ROOT_DIR%\" (
    echo ERROR: Directory "%ROOT_DIR%" does not exist.
    exit /b 1
)

REM --- Block dangerous root paths ---
SET "CHECK_PATH=%ROOT_DIR%"
REM Normalize: strip trailing backslash for comparison
IF "%CHECK_PATH:~-1%"=="\" SET "CHECK_PATH=%CHECK_PATH:~0,-1%"

FOR %%B IN (
    "C:"
    "C:\Windows"
    "C:\Users"
    "C:\Program Files"
    "C:\Program Files (x86)"
    "D:"
    "E:"
) DO (
    IF /I "%CHECK_PATH%"==%%~B (
        echo ERROR: Refusing to run against system/root path "%CHECK_PATH%".
        echo        Please provide a more specific project directory.
        exit /b 1
    )
)

REM --- First pass: collect qualifying node_modules directories ---
echo Scanning "%ROOT_DIR%" for node_modules with sibling package.json...
echo.

SET "COUNT=0"
SET "TMPFILE=%TEMP%\nm_cleanup_%RANDOM%.txt"
IF EXIST "%TMPFILE%" DEL "%TMPFILE%"

FOR /D /R "%ROOT_DIR%" %%D IN (node_modules) DO (
    IF EXIST "%%D" (
        SET "NM_PATH=%%D"
        SET "PARENT=%%~dpD"
        REM Skip if nested inside another node_modules
        SET "NM_CHECK=!PARENT:node_modules=!"
        IF "!NM_CHECK!"=="!PARENT!" (
            REM Check for sibling package.json
            IF EXIST "!PARENT!package.json" (
                SET /A COUNT+=1
                echo   !COUNT!. %%D
                echo %%D>>"%TMPFILE%"
            )
        )
    )
)

echo.

IF %COUNT%==0 (
    echo No qualifying node_modules directories found.
    IF EXIST "%TMPFILE%" DEL "%TMPFILE%"
    exit /b 0
)

echo Found %COUNT% node_modules director(ies).
echo.

REM --- Dry-run mode ---
IF %DO_DELETE%==0 (
    echo Dry run -- use /delete to remove these directories.
    IF EXIST "%TMPFILE%" DEL "%TMPFILE%"
    exit /b 0
)

REM --- Delete mode ---
SET "ERRORS=0"
SET "DELETED=0"
SET "SKIPPED=0"
FOR /F "usebackq delims=" %%L IN ("%TMPFILE%") DO (
    IF EXIST "%%L" (
        IF !SKIP_CONFIRM!==1 (
            echo Removing "%%L"...
            rd /s /q "%%L"
            IF ERRORLEVEL 1 (
                echo   WARNING: Failed to remove "%%L" - may be locked by a running process
                SET "ERRORS=1"
            ) ELSE (
                SET /A DELETED+=1
            )
        ) ELSE (
            SET /P "ANSWER=Delete "%%L"? (Y/N): "
            IF /I "!ANSWER!"=="Y" (
                echo   Removing...
                rd /s /q "%%L"
                IF ERRORLEVEL 1 (
                    echo   WARNING: Failed to remove "%%L" - may be locked by a running process
                    SET "ERRORS=1"
                ) ELSE (
                    SET /A DELETED+=1
                )
            ) ELSE (
                echo   Skipped.
                SET /A SKIPPED+=1
            )
        )
    )
)

IF EXIST "%TMPFILE%" DEL "%TMPFILE%"

echo.
echo Deleted !DELETED! of %COUNT% directories.
IF !SKIPPED! GTR 0 echo Skipped !SKIPPED!.
IF %ERRORS%==1 (
    echo Completed with errors.
    exit /b 1
) ELSE (
    echo Completed successfully.
    exit /b 0
)
